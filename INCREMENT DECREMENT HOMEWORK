package operator;

public class darshan {
	public static void main(String[] args) {
		int i =90;
		i++;
		int j =i+9;
		System.out.println(i++);
		
		--j;
		System.out.println(j*i);
		i++;
		--i;
		System.out.println(--i);
		++i;
		System.out.println(j+3);

		j--;
		++j;
		System.out.println(j+7);
		j--;
		i++; 
		System.out.println(j);
		--i;

		System.out.println(i+j);
		System.out.println(i);
		System.out.println(j);
		
		
	}

}

